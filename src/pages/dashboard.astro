---
import Layout from "@/layouts/Layout.astro";

const { user } = Astro.locals;
---

<Layout title="Panel">
  <div class="bg-sand flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card text-foreground rounded-2xl border p-8 text-center shadow-sm">
      <h1 class="text-foreground mb-4 text-3xl font-bold">Panel</h1>
      <p class="text-muted-foreground">
        Witaj, <span class="text-foreground font-semibold">{user?.email}</span>
      </p>
      <p class="text-muted-foreground mt-2 text-sm">Ta strona jest dostępna tylko dla zalogowanych użytkowników.</p>
      <form method="POST" action="/api/auth/signout" class="mt-6">
        <button
          type="submit"
          class="border-border bg-secondary hover:bg-muted rounded-lg border px-4 py-2 text-sm transition-colors"
        >
          Wyloguj
        </button>
      </form>
    </div>
  </div>
</Layout>
