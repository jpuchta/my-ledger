---
import Layout from "@/layouts/Layout.astro";
import SignUpForm from "@/components/auth/SignUpForm";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Załóż konto">
  <div class="bg-sand flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card text-foreground w-full max-w-sm rounded-2xl border p-8 shadow-sm">
      <h1 class="text-foreground mb-6 text-center text-2xl font-bold">Załóż konto</h1>
      <SignUpForm serverError={error} client:load />
      <p class="text-muted-foreground mt-4 text-center text-sm">
        Masz już konto? <a href="/auth/signin" class="text-accent-strong hover:underline">Zaloguj się</a>
      </p>
    </div>
  </div>
</Layout>
