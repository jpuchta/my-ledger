---
import Layout from "@/layouts/Layout.astro";

const isAutoConfirmed = import.meta.env.DEV;

const content = isAutoConfirmed
  ? {
      emoji: "✅",
      heading: "Rejestracja zakończona",
      description: "Konto zostało utworzone. Możesz się teraz zalogować.",
      linkText: "Przejdź do logowania",
    }
  : {
      emoji: "📧",
      heading: "Sprawdź skrzynkę",
      description: "Wysłaliśmy link aktywacyjny na Twój adres e-mail. Kliknij go, aby aktywować konto.",
      linkText: "Wróć do logowania",
    };
---

<Layout title={content.heading}>
  <div class="bg-sand flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card text-foreground w-full max-w-sm rounded-2xl border p-8 text-center shadow-sm">
      <div class="mb-4 text-5xl">{content.emoji}</div>
      <h1 class="text-foreground mb-3 text-2xl font-bold">{content.heading}</h1>
      <p class="text-muted-foreground mb-6">{content.description}</p>
      <a href="/auth/signin" class="text-accent-strong text-sm hover:underline">{content.linkText}</a>
    </div>
  </div>
</Layout>
