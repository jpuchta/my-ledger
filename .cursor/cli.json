{
  "version": 1,
  "permissions": {
    "allow": [
      "Shell(npm)",
      "Shell(npx)",
      "Shell(node)",
      "Shell(git:add*)",
      "Shell(git:commit*)",
      "Shell(git:diff*)",
      "Shell(git:log*)",
      "Shell(git:status*)",
      "Shell(git:status)",
      "Shell(git:branch*)",
      "Shell(git:checkout*)",
      "Shell(git:stash*)",
      "Read(**)",
      "Write(**)"
    ],
    "deny": [
      "Shell(rm:-rf*)",
      "Shell(rm:-fr*)",
      "Read(../*)",
      "Read(../**)",
      "Write(../*)",
      "Write(../**)",
      "Read(/**)",
      "Write(/**)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.dev.vars)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.dev.vars)",
      "Read(supabase/.env.keys)",
      "Read(supabase/.env.local)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)",
      "Write(.dev.vars)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.production)",
      "Write(**/.dev.vars)",
      "Write(supabase/.env.keys)",
      "Write(supabase/.env.local)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/id_rsa)",
      "Write(**/id_rsa.*)"
    ]
  }
}
